  _       _    _    _    _    _    _    _    _    _     _       _     _           _         _
  _       y    S-w  S-f  _    _    _    _    _    _     _       _     _           _         _
  _       S-5  S-c  S-d  S-v  _    _    _    S-o    _     _       _                 _         _
