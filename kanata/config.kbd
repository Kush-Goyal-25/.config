  _       _    _    _    _    _    _    _    _    _     _       _     _           _         _
  _       8    7    6    5    _    _    _    _    _     S-;     _     _           _         _
  _       4    3    2    1    _    _    _    b    j     k       ,                 _         _
  _       _    0    9    _    _    _    _    _    ;     .                         _    _    _
  _       _    _              _              _    _     _                         _    _    _
