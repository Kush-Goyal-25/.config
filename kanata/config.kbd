 | )
 | esc  f1   f2   f3   f4   f5   f6   f7   f8   f9   f10  f11   f12 home ins  del
 | grv  1    2    3    4    5    6    7    8    9    0    -     =        bspc
 | tab  q    w    e    r    t    y    u    i    o    p    [     ]        ret
 | caps a    s    d    f    g    h    j    k    l    ;    '     `        ret
 | lsft \    z    x    c    v    b    n    m    ,    .    /              rsft
 |      lctl lmet lalt           spc            ralt prnt rctl      pgup up   pgdn
 |                                                                  lft down rght
 -------------------------------------------------------------------------- |#

(defcfg
  linux-dev /dev/input/by-id/usb-SINO_WEALTH_Gaming_KB-event-kbd
  process-unmapped-keys yes
  concurrent-tap-hold yes
)

(defalias mt (macro M-S-ret))

(defalias
  f1 (macro M-S-1)
  f2 (macro M-S-2)
  f3 (macro M-S-3)
  f4 (macro M-S-4)
  f5 (macro M-S-5)
  f6 (macro M-S-6)
  f7 (macro M-S-7)
  f8 (macro M-S-8)
  f9 (macro M-S-9)
)

(defalias
  s_und S-min
  ca C-q
  cz C-z
  cx C-x
  cc C-c
  cv C-v
  atb A-tab
  caps (tap-hold 15 15 caps bspc)
  rsft (tap-hold 15 15 rsft caps)
  a (tap-hold-release 200 200 a lmet)
  s (tap-hold-release 200 200 s lalt)
  d (tap-hold-release 200 200 d lsft)
  f (tap-hold-release 200 200 f lctl)
  j (tap-hold-release 200 200 j rctl)
  k (tap-hold-release 200 200 k rsft)
  l (tap-hold-release 200 200 l ralt)
  sem (tap-hold-release 200 200 ; rmet)
  y-pipe (tap-hold 250 250 y (macro C-q S-\))
  t-pipe (tap-hold 250 250 t (macro C-q -))
  h-pipe (tap-hold 200 200 h (macro C-q l C-q l))
  g-pipe (tap-hold 200 200 g (macro C-q h C-q h))
  q-pipe (tap-hold 300 300 q (macro C-q S-9))
  r-pipe (tap-hold 300 300 r (macro C-q S-l))
  c-pipe (tap-hold 200 200 c C-S-l)
)

(defalias
  S1 S-1
  S2 S-2
  S3 S-3
  S4 S-4
  S5 S-5
  S6 S-6
  S7 S-7
  S8 S-8
  S9 S-9
  S0 S-0
  Sbs S-\
  Sgr S-grv
  Seq S-=
  Scm S-,
  Sdt S-.
  Slb S-[
  Srb S-]
  Ssl S-/
)

(defalias
  mod_prog (layer-toggle program)
  mod_util (layer-toggle util)
  mod_util2 (layer-toggle util2)
  capi (layer-toggle capi)
)

(defalias
  stog  (tap-hold-release 200 200 spc @mod_prog)
  tut   (tap-hold-release 20 20 lsft @mod_util)
  cutil (tap-hold-release 20 20 caps bspc)
  tut2  (tap-hold-release 150 150 ret @mod_util2)
  test  (tap-hold-release 20 20 [ @capi)
)

(defchordsv2
  (a ;) esc 250 all-released ()
)

(defvar
  tap-time 400
  hold-time 400
)

(defsrc
                                                                                  end
  esc   f1   f2   f3   f4   f5   f6   f7   f8   f9   f10  f11   f12         prnt  ins  pause
  grv   1    2    3    4    5    6    7    8    9    0    -     =           bspc       home
  tab   q    w    e    r    t    y    u    i    o    p    [     ]           \          del
  caps  a    s    d    f    g    h    j    k    l    ;    '                 ret        pgup
  lsft  z    x    c    v    b    n    m    ,    .    /                      rsft up    pgdn
  lctl  lmet lalt               spc        ralt cmp  rctl                   lft down  rght
)

(deflayer qwerty
                                                                                    d
  esc   @f1   @f2   @f3   @f4   @f5   @f6   @f7   @f8   @f9   f10  f11   f12         prnt  ins  pause
  grv   1    2    3    4    5    6    7    8    9    0    -     =           bspc       home
  tab   @q-pipe    w    e    @r-pipe    @t-pipe    @y-pipe    u    i    o    p    @test     ]           \          del
  @caps @a   @s   @d   @f   @g-pipe    @h-pipe    @j    @k   @l   @sem  '                 @tut2        pgup
  @tut  z    x    @c-pipe    v    b    n    m    ,    .    /                      @rsft up    pgdn
  _  lmet @ca               @stog        @mt cmp  rctl                   lft down  rght
)

(deflayer program
                                                                                       _
  _       _    _    _    _    _    _    _    _    _    _       _       _          _    _    _
  @atb    @S1  @S2  @S3  @S4  @S5  @S6  @S7  @S8  @S9  @S0     @s_und  @Seq       _         _
  _       8    7    6    5    _    S-6   @Slb  @Srb  +   @S2     {       }          _      _
  _       4    3    2    1    S-3   lmet  @S9  @S0  @S1   =      @Ssl               _         _
  _       _    0    9    _    @Sbs  -    [    ]    \    @Ssl                        _    _    _
  _       _    _              _              _    _    _                          _    _    _
)

