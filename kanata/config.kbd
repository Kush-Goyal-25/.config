  _       _    _    _    _    _    _    _    _    _     _       _     _           _         _
  _       _    _    _    _    _    _    @S5   @Sgr  @S8   @S7     _     _           _         _
  _       _    _    S-,    -    _    lft   down  up   rght  =       _                 _         _
  _       _    _    _    _    _    grv   S-;   =    spc   _                         _    _    _
  _       _    _              _              _    _     _                         _    _    _
